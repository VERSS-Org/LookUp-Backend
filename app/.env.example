# Ejemplo de variables de entorno para el proyecto.
# Copia este archivo a `.env` y ajusta los valores antes de ejecutar.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postulaciones_db
SECRET_KEY=change-me-in-local-env
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
ENABLE_SWAGGER=true
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postulaciones_db
