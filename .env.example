# Database
# Use a local database while developing or paste your private Supabase URL in your untracked .env file.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postulaciones_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postulaciones_db

# JWT
# Generate a strong value for deployed environments. Never commit real secrets.
SECRET_KEY=change-me-in-local-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# Environment
ENVIRONMENT=development
ENABLE_SWAGGER=true
